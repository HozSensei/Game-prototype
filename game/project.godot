; Engine configuration file.
; Godot 4.3 — Ninja Arena prototype (working title)

config_version=5

[application]

config/name="Ninja Arena"
config/description="Duel d'arène ninja (prototype v1) — souls-like timing + techniques."
run/main_scene="res://scenes/arena.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameBus="*res://scripts/game_bus.gd"
InputSetup="*res://scripts/input_setup.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

